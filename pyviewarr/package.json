{
	"scripts": {
		"build:deps": "cd viewarr && npm run build",
		"build:deps:dev": "cd viewarr && npm run build:dev",
		"build:all": "npm run build:deps && npm run build",
		"build:dev": "npm run build:deps:dev && npm run build",
		"dev": "node build.mjs --dev --watch",
		"build": "node build.mjs",
		"typecheck": "tsc --noEmit",
		"test:e2e": "npm run build:all && playwright test",
		"test:e2e:headed": "npm run build:all && playwright test --headed",
		"test:e2e:install": "playwright install chromium"
	},
	"dependencies": {
		"viewarr": "file:./viewarr"
	},
	"devDependencies": {
		"@anywidget/types": "^0.2.0",
		"@jupyterlab/galata": "^5.5.4",
		"@playwright/test": "^1.57.0",
		"typescript": "^5.8.3",
		"esbuild": "^0.25.4"
	}
}
